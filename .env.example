# ── Backend (required) ────────────────────────────────────────────
# Neon Postgres connection string.
# Vercel: added automatically when you connect Neon from the Storage tab,
# or paste it manually in Project Settings → Environment Variables.
DATABASE_URL=

# Secret used to sign session tokens (JWT). Use a long random string.
JWT_SECRET=

# ── Payments ──────────────────────────────────────────────────────
# Stripe secret key (server side) — sk_test_... first, sk_live_... when ready.
STRIPE_SECRET_KEY=
# Stripe publishable key (browser side) — pk_test_... / pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=

# PayPal client ID for the PayPal checkout button (optional)
VITE_PAYPAL_CLIENT_ID=

# ── Social login (optional — buttons show a friendly message until set) ──
# Google: console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID (Web application). Use the SAME value for both.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Facebook: developers.facebook.com → your app → Settings → Basic.
# App ID goes in both; App Secret stays server-side only.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
VITE_FACEBOOK_APP_ID=

# ── Optional ──────────────────────────────────────────────────────
# First account registered with this email becomes the platform admin.
ADMIN_BOOTSTRAP_EMAIL=zahidyaftali999@gmail.com

# Resend API key — enables "forgot password" emails. Leave empty to disable.
RESEND_API_KEY=
RESET_EMAIL_FROM=

# Public URL of the site (used in password-reset links).
APP_URL=https://jazba-ticket.vercel.app

# Local dev only: port for `npm run dev:api`.
API_PORT=8787
