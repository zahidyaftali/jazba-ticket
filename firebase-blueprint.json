{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "organizer", "artist", "user"] },
        "profileImage": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] }
      },
      "required": ["uid", "email", "name", "role", "status", "createdAt"]
    },
    "Organizer": {
      "title": "Organizer",
      "description": "Organizer profile and meta settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "logo": { "type": "string" },
        "banner": { "type": "string" },
        "description": { "type": "string" },
        "website": { "type": "string" },
        "socialLinks": { "type": "object" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["userId", "companyName", "email"]
    },
    "Artist": {
      "title": "Artist",
      "description": "Artist performance portfolio profile",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "stageName": { "type": "string" },
        "bio": { "type": "string" },
        "profileImage": { "type": "string" },
        "coverImage": { "type": "string" },
        "genres": { "type": "array" },
        "socialLinks": { "type": "object" }
      },
      "required": ["userId", "stageName"]
    },
    "Event": {
      "title": "Event",
      "description": "Premium show, concert, or theater event item",
      "type": "object",
      "properties": {
        "organizerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "venue": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "bannerImage": { "type": "string" },
        "galleryImages": { "type": "array" },
        "artists": { "type": "array" },
        "ticketTypes": { "type": "object" },
        "capacity": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "published", "cancelled", "completed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["organizerId", "title", "venue", "city", "date", "status", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Order records for admissions tickets",
      "type": "object",
      "properties": {
        "bookingNumber": { "type": "string" },
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "ticketType": { "type": "string" },
        "quantity": { "type": "number" },
        "amount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "bookingStatus": { "type": "string", "enum": ["active", "cancelled", "completed"] },
        "qrCode": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["bookingNumber", "eventId", "userId", "ticketType", "quantity", "amount", "paymentStatus", "bookingStatus", "createdAt"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Specific entrance passes mapped to bookings",
      "type": "object",
      "properties": {
        "ticketNumber": { "type": "string" },
        "bookingId": { "type": "string" },
        "userId": { "type": "string" },
        "eventId": { "type": "string" },
        "qrCode": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "cancelled", "scanned"] }
      },
      "required": ["ticketNumber", "bookingId", "userId", "eventId", "qrCode", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Financial cleared ledger information",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "provider": { "type": "string", "enum": ["stripe", "easypaisa", "jazzcash", "paypal"] },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["bookingId", "userId", "amount", "currency", "provider", "transactionId", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or security triggers notifications collection",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Platform aggregate counters metrics",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalOrganizers": { "type": "number" },
        "totalArtists": { "type": "number" },
        "totalEvents": { "type": "number" },
        "totalTicketsSold": { "type": "number" },
        "totalRevenue": { "type": "number" }
      },
      "required": ["totalUsers", "totalOrganizers", "totalArtists", "totalEvents", "totalTicketsSold", "totalRevenue"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User custom credential roles"
    },
    "organizers/{organizerId}": {
      "schema": "Organizer",
      "description": "Show organizer business records"
    },
    "artists/{artistId}": {
      "schema": "Artist",
      "description": "Artist bios and portfolio"
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Dynamic custom concert shows and ticketing listings"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Admissions seating reservation orders"
    },
    "tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Secured individual barcode access ticket items"
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Cleared financial invoices transactions history"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Direct personalized system messages and alerts logs"
    },
    "analytics/{analyticsDocId}": {
      "schema": "Analytics",
      "description": "Aggregated platform performance metrics dashboard"
    }
  }
}
